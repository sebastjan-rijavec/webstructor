{
  "name": "webstructor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Three.js kitbashing tool with GLB export",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && rsync -avz --delete dist/ seb@192.168.1.3:/var/www/webstructor/"
  },
  "dependencies": {
    "n8ao": "^1.10.1",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/three": "^0.169.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
