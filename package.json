{
  "name": "webstructor",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "Three.js kitbashing tool with GLB export",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && rsync -avz --delete dist/ seb@192.168.1.3:/var/www/webstructor/",
    "release:patch": "commit-and-tag-version --release-as patch && npm run release:publish",
    "release:minor": "commit-and-tag-version --release-as minor && npm run release:publish",
    "release:major": "commit-and-tag-version --release-as major && npm run release:publish",
    "release:publish": "node scripts/release-publish.mjs"
  },
  "dependencies": {
    "n8ao": "^1.10.1",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/three": "^0.169.0",
    "commit-and-tag-version": "^12.7.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
